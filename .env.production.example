# ── Django ──────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DEBUG=False
ALLOWED_HOSTS=patpipes.com,www.patpipes.com,api.patpipes.com,147.93.96.76

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=patent_analytics_db
POSTGRES_USER=patent_user
POSTGRES_PASSWORD=change-me-strong-password

# ── CORS (frontend origins the browser connects from) ────
CORS_ALLOWED_ORIGINS=https://patpipes.com,https://www.patpipes.com

# ── Frontend ─────────────────────────────────────────────
# Public URL of the backend API (what the browser can reach)
NEXT_PUBLIC_API_URL=https://api.patpipes.com

# ── External APIs (copy from your local .env) ────────────
# NOTE: the USPTO var MUST be USPTO_ODP_API_KEY — that is the name settings reads
# (config('USPTO_ODP_API_KEY')). A bare USPTO_API_KEY is ignored, leaving the backend
# with no key and breaking claim auto-import / all ODP lookups.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USPTO_ODP_API_KEY=
LENS_API_KEY=
